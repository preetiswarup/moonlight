        <mxCell id="cELoAPxVr8Mn17AUm24W-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;&quot;&gt;&lt;div&gt;Step 4-&amp;nbsp; Parse number · (year only)&lt;/div&gt;&lt;div&gt;Input:&amp;nbsp; {year_text} = year as a text string, e.g. &quot;1930&quot;&lt;/div&gt;&lt;div&gt;Output: {year_int} = year as an integer number, e.g. 1930&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Note: converts the string &quot;1930&quot; into the number 1930 (Int data type)&lt;/div&gt;&lt;div&gt;{year_int} stored for this row&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="93" width="390" x="180" y="461" as="geometry" />
